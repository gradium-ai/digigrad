# gradphone configuration — copy to .env and fill in the values.
# scripts/setup.sh creates this for you and generates BRIDGE_API_KEY + local
# defaults; scripts/run_local.sh fills in the PUBLIC_* URLs from the tunnel.

# ── Required ──────────────────────────────────────────────────────────────

# Your Gradium API key — powers STT, TTS, and voice cloning (gsk_…).
GRADIUM_API_KEY=
# Default agent voice UID for calls — a voice in your own Gradium account.
AGENT_VOICE_ID=
# OpenAI API key (sk-…). Omit if you point LLM_BASE_URL at another host.
OPENAI_API_KEY=
# Bearer token for the bridge API + session-cookie signing key (>=16 chars).
BRIDGE_API_KEY=
# Telegram bot token from @BotFather (needed to run the bot).
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to use the bot (find via @userinfobot).
ALLOWED_TELEGRAM_IDS=

# ── LLM endpoint (optional overrides) ───────────────────────────────────────

# OpenAI-compatible endpoint; change for a non-OpenAI host (Groq, vLLM, …).
LLM_BASE_URL=https://api.openai.com/v1
# Model name; auto-detected if the endpoint exposes exactly one.
LLM_MODEL=gpt-4o-mini

# ── Twilio (required for phone calls) ───────────────────────────────────────

# Account SID (AC…).
TWILIO_ACCOUNT_SID=
# Auth token — also used to verify Twilio's signature on incoming webhooks.
TWILIO_AUTH_TOKEN=
# Your Twilio number in E.164.
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Optional: override the "from" number on outbound calls.
TWILIO_FROM_NUMBER=
# Voicemail detection: Enable | DetectMessageEnd | disable.
TWILIO_MACHINE_DETECTION=Enable

# ── Public reachability (set automatically by run_local.sh) ─────────────────

# Public https URL of your tunnel (cloudflared/ngrok) so Twilio can reach you.
PUBLIC_HTTP_URL=
# Public wss URL of the same tunnel.
PUBLIC_WS_URL=

# ── Outbound call guard ─────────────────────────────────────────────────────

# true = dial any number; false = only numbers in OUTBOUND_ALLOWLIST.
ALLOW_ARBITRARY_OUTBOUND=false
# Comma-separated allowed destination numbers (E.164) when the guard is on.
OUTBOUND_ALLOWLIST=

# ── Inbound / receptionist mode (optional) ──────────────────────────────────

# true = answer incoming calls to TWILIO_PHONE_NUMBER as a receptionist.
ENABLE_INBOUND=false
# Voice UID for inbound answers (blank = per-language default).
INBOUND_VOICE_ID=
# Language for the inbound greeting.
INBOUND_LANGUAGE=en
# Owner name used in greetings and voicemail text.
OPERATOR_NAME=Acme
# Telegram chat id that receives relayed messages (default: first ALLOWED id).
OPERATOR_TELEGRAM_ID=
# true = leave a short voicemail when a machine answers.
ENABLE_VOICEMAIL_MESSAGE=false

# ── Assistant-mode features (optional) ──────────────────────────────────────

# Gmail address for "summarize my emails" (IMAP, needs an App Password).
GMAIL_ADDRESS=
# Gmail App Password (2FA required): https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
# Linkup key for live web search on calls: https://app.linkup.so
LINKUP_API_KEY=
# Google Places key for business lookup.
GOOGLE_PLACES_API_KEY=
# Force a specific voice for translated speech-to-speech output (/translate).
GRADIUM_TRANSLATE_VOICE_ID=

# ── Limits ──────────────────────────────────────────────────────────────────

# Max concurrent Gradium STT sessions (0 = no cap).
GRADBOT_MAX_CONCURRENT=3
# Hard per-call hangup deadline in seconds (0 = disabled).
MAX_CALL_DURATION_SECONDS=600

# ── Database (optional; default: local SQLite at ~/.gradphone/gradphone.db) ──

# Override the SQLite file path.
GRADPHONE_DB=
# Full Postgres URL for hosted deploys (postgresql+psycopg://user:pass@host/db).
DATABASE_URL=

# ── Local-dev only — NEVER set these on a public host ───────────────────────

# 1 = disable auth + Twilio signature checks and let the bot accept everyone.
ALLOW_INSECURE_LOCAL=
# 1 = drop the Secure flag on session cookies (local HTTP dev only).
INSECURE_COOKIES=
